# Control Plane Admin API Key (Required for starting the API server)
CONTROL_PLANE_ADMIN_KEY="your-secret-admin-key"

# Callback Token (Required — used by LiteLLM proxy nodes to POST events to /events/callback)
# Must be different from CONTROL_PLANE_ADMIN_KEY. Generate with: openssl rand -hex 32
CONTROL_PLANE_CALLBACK_TOKEN="your-secret-callback-token"

# Doppler Secret Fallback (Optional, default: false)
# When true, falls back to local env vars if Doppler resolution fails.
# ONLY enable in local dev/test. NEVER set to true in production.
# ALLOW_ENV_SECRET_FALLBACK=false

# Doppler Service Tokens (Scoped per environment/config)
# Format: DOPPLER_TOKEN_<PROJECT>_<CONFIG> (in uppercase, non-alphanumeric normalized to underscores)
# Example:
# DOPPLER_TOKEN_ALL_FREE_API_TOKENS_PRD_KR="dp.st.prd.xxxxxx"

# LiteLLM Proxy Node Master Keys (Used by the adapter to authenticate against LiteLLM)
# Format: LITELLM_MASTER_KEY_<NODE_ID> (in uppercase, non-alphanumeric normalized to underscores)
# Example:
# LITELLM_MASTER_KEY_GW_KR="your-litellm-node-master-key"
